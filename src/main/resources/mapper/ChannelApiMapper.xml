<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.conk.integration.query.mapper.ChannelApiMapper">

    <select id="findShopifyCredential"
            parameterType="string"
            resultType="com.conk.integration.query.dto.ShopifyCredentialDto">
        SELECT store_name  AS storeName,
               channel_api AS accessToken
        FROM   channel_api
        WHERE  seller_id   = #{sellerId}
          AND  channel_name = 'SHOPIFY'
    </select>

</mapper>
